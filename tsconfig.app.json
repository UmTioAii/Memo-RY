{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "types": ["vitest/globals"], // Remova esta linha se não usar Vitest
    "jsx": "react-jsx",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}